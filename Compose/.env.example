# McRubes Media Server — Environment Variables
# -----------------------------------------------
# Run everything as root — no permission restrictions
PUID=
PGID=

# Timezone
TZ=

# Paths
MEDIA_PATH=
DOCKER_PATH=

# PIA VPN (used by qBittorrent container)
PIA_USER=
PIA_PASSWORD=
PIA_REGION=

# Plex Claim Token
# Get a fresh token at https://plex.tv/claim (expires in 4 minutes)
# After first successful Plex start this is no longer needed
PLEX_CLAIM=

# Watchtower API token
WATCHTOWER_TOKEN=
